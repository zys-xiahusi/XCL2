<local:MyPageRight
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:PCL"
    x:Class="PageOtherXenith"
    PanScroll="PanBack"
    RenderOptions.BitmapScalingMode="LowQuality">
    <local:MyScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" x:Name="PanBack">
        <Grid x:Name="PanMain" Margin="25,10">
            <Border Background="{DynamicResource ColorBrushBg1}" CornerRadius="8" Padding="40">
                <StackPanel>
                    <TextBlock Text="XENITH 登录" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource ColorBrush2}" HorizontalAlignment="Center" Margin="0,0,0,30"/>
                    <TextBlock Text="服务器地址" Foreground="{DynamicResource ColorBrush2}" Margin="0,0,0,5"/>
                    <TextBox x:Name="TextServerUrl" Height="35" Padding="5" Margin="0,0,0,15" Text="http://192.168.1.104:3000"/>
                    <TextBlock Text="账号" Foreground="{DynamicResource ColorBrush2}" Margin="0,0,0,5"/>
                    <TextBox x:Name="TextUsername" Height="35" Padding="5" Margin="0,0,0,15"/>
                    <TextBlock Text="密码" Foreground="{DynamicResource ColorBrush2}" Margin="0,0,0,5"/>
                    <PasswordBox x:Name="TextPassword" Height="35" Padding="5" Margin="0,0,0,20"/>
                    <local:MyButton x:Name="BtnLogin" Text="登录" Height="40" ColorType="Highlight" Margin="0,0,0,10"/>
                    <local:MyButton x:Name="BtnRegister" Text="注册账号" Height="35" ColorType="Normal" Margin="0,0,0,10"/>
                    <TextBlock x:Name="LabStatus" Foreground="{DynamicResource ColorBrush2}" HorizontalAlignment="Center" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Grid>
    </local:MyScrollViewer>
</local:MyPageRight>
